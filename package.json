{
  "name": "wechat-codex",
  "version": "1.0.0",
  "description": "WeChat-Codex bridge with interactive terminal REPL and WeChat dual input",
  "type": "module",
  "bin": {
    "wechat-codex": "./dist/src/main.js"
  },
  "scripts": {
    "build": "tsc",
    "postinstall": "npm run build",
    "start": "node dist/src/main.js",
    "dev": "tsc --watch",
    "setup": "node dist/src/main.js setup",
    "codex-auth": "node dist/src/main.js codex-auth",
    "cleanup-legacy": "node dist/src/main.js cleanup-legacy"
  },
  "dependencies": {
    "node-pty": "^1.1.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "wechat",
    "codex",
    "openai",
    "agent",
    "cli",
    "bridge",
    "repl"
  ],
  "license": "MIT"
}
